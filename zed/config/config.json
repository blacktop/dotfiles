{
  // Editor
  "cli_default_open_behavior": "existing_window",
  "focus_follows_mouse": {
    "enabled": false
  },
  "outline_panel": {
    "dock": "right"
  },
  "collaboration_panel": {
    "dock": "right"
  },
  "vim_mode": false,
  "base_keymap": "Atom",
  "soft_wrap": "editor_width",
  "preferred_line_length": 120,
  "scroll_beyond_last_line": "vertical_scroll_margin",
  "colorize_brackets": true,
  "word_diff_enabled": true,
  "diff_view_style": "unified",
  "use_system_window_tabs": true,

  // Appearance
  "theme": "Fleet Dark Purple",
  "minimap": { "show": "always" },
  "tabs": { "file_icons": true },
  "scrollbar": { "git_diff": true },
  "project_panel": { "dock": "left", "show_diagnostics": "all" },

  // Fonts
  "ui_font_family": "MonoLisa Nerd Font",
  "ui_font_size": 14.0,
  "buffer_font_family": "OperatorMono Nerd Font Mono",
  "buffer_font_size": 13.0,
  "buffer_font_features": {
    "liga": true,
    "calt": true,
    "titl": true
  },

  // Terminal
  "terminal": {
    "font_family": "MesloLGLDZ Nerd Font Mono",
    "font_size": 12.0,
    "font_features": { "calt": true },
    "line_height": { "custom": 1.5 },
    "blinking": "off",
    "shell": {
      "with_arguments": {
        "program": "/opt/homebrew/bin/fish",
        "args": ["-c", "tmux new-session -A -s \"$(basename \"$PWD\")\""]
      }
    }
  },

  // Git
  "git_panel": {
    "dock": "left",
    "tree_view": true,
    "sort_by_path": false
  },

  // Edit predictions
  "edit_predictions": {
    "provider": "zed",
    "disabled_globs": ["**/.env*", "**/*.pem", "**/*.key", "**/secrets/**", "**/private/**"]
  },

  // Languages
  "languages": {
    "Swift": {
      "enable_language_server": false,
      "language_servers": ["sourcekit-lsp"],
      "formatter": "language_server",
      "format_on_save": "on",
      "tab_size": 2
    },
    "Python": {
      "enable_language_server": true,
      "language_servers": ["ty", "ruff", "!basedpyright", "!pyrefly", "!pyright", "!pylsp"]
    }
  },

  // LSP
  "lsp": {
    "sourcekit-lsp": {
      "binary": {
        "path": "/Applications/Xcode.app/Contents/Developer/Toolchains/XcodeDefault.xctoolchain/usr/bin/sourcekit-lsp"
      }
    },
    "pyrefly": {
      "binary": {
        "path": "pyrefly",
        "arguments": ["lsp"]
      },
      "settings": {
        "python": { "pythonPath": ".venv/bin/python" },
        "pyrefly": {
          "project_includes": ["**/*.py", "tests/**/*.py"],
          "project_excludes": ["**/.[!/.]*", "**/*venv/**"],
          "ignore_errors_in_generated_code": true
        }
      }
    },
    "clangd": {
      "binary": {
        "path": "/usr/bin/clangd",
        "arguments": [
          "--background-index",
          "--header-insertion=never",
          "--limit-results=5000",
          "--enable-config",
          "-j",
          "10"
        ]
      }
    }
  },

  // File types
  "file_types": {
    "Scheme": ["sb", "in"],
    "TOML": ["toml", "toml.example"]
  },

  // File exclusions
  "file_scan_exclusions": [
    "**/locals.fish",
    "**/.git",
    "**/node_modules",
    "**/.env",
    "**/secrets/**",
    "**/private/**",
    "**/.cache",
    "**/.ssh",
    "**/.DS_Store"
  ],
  "private_files": ["**/locals.fish", "**/.env", "**/secrets/**", "**/private/**", "**/.cache", "**/.ssh"],

  // Agent
  "agent": {
    "sidebar_side": "right",
    "dock": "right",
    "enabled": true,
    "play_sound_when_agent_done": "always",
    "default_profile": "write",
    "tool_permissions": { "default": "confirm" },
    "commit_message_model": {
      "provider": "copilot_chat",
      "model": "claude-sonnet-4.6"
    },
    "inline_assistant_model": {
      "provider": "copilot_chat",
      "model": "claude-sonnet-4.6"
    },
    "default_model": {
      "provider": "copilot_chat",
      "model": "claude-opus-4.6"
    },
    "profiles": {
      "write": {
        "name": "Write",
        "tools": {
          "search_web": true,
          "batch_tool": false,
          "code_actions": false,
          "code_symbols": false,
          "contents": false,
          "copy_path": false,
          "create_file": true,
          "delete_path": false,
          "diagnostics": true,
          "edit_file": true,
          "fetch": true,
          "find_path": true,
          "grep": true,
          "list_directory": true,
          "move_path": false,
          "now": false,
          "read_file": true,
          "rename": false,
          "symbol_info": false,
          "terminal": true,
          "thinking": true,
          "web_search": true
        },
        "enable_all_context_servers": true,
        "context_servers": {
          "say": { "tools": { "say": false } }
        }
      }
    }
  },

  // Agent servers
  "agent_servers": {
    "claude-acp": { "type": "registry" },
    "codex-acp": { "type": "registry" },
    "gemini": { "type": "registry" }
  },

  // Language models
  "language_models": {
    "lmstudio": {
      "api_url": "http://bmo:3993/api/v0",
      "available_models": [
        {
          "name": "mlx-community/gemma-4-e4b-it-8bit",
          "max_tokens": 50000,
          "supports_images": true,
          "supports_tool_calls": true
        }
      ]
    }
  },

  // Context servers (add API keys locally)
  "context_servers": {},

  // Extensions (auto-installed on startup)
  "auto_install_extensions": {
    // Languages
    "assembly": true,
    "dockerfile": true,
    "fish": true,
    "html": true,
    "ini": true,
    "just": true,
    "log": true,
    "make": true,
    "nix": true,
    "pyrefly": true,
    "scheme": true,
    "svelte": true,
    "swift": true,
    "toml": true,
    "xml": true,
    "zig": true,
    // Themes
    "catppuccin": true,
    "fleet-themes": true,
    "palenight": true,
    "rose-pine-theme": true,
    "tokyo-night": true,
    // MCP servers
    "mcp-server-context7": true,
    "mcp-server-exa-search": true,
    "shadcn-mcp": true,
    "svelte-mcp": true
  },

  // Telemetry
  "telemetry": {
    "diagnostics": false,
    "metrics": false
  }
}
