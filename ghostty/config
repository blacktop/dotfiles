# vi:ft=conf
# https://github.com/ghostty-org/ghostty/blob/main/src/config/Config.zig

# ── General ──────────────────────────────────────────────────────────────────
auto-update-channel = tip
quit-after-last-window-closed = true
confirm-close-surface = false
scrollback-limit = 10_000_000_000

# ── Window ───────────────────────────────────────────────────────────────────
window-save-state = always
window-decoration = true
window-theme = dark

# ── macOS ────────────────────────────────────────────────────────────────────
macos-option-as-alt = true
macos-auto-secure-input = true
macos-secure-input-indication = true
# Keep Shift-drag as Ghostty-native selection even when tmux enables mouse
# reporting, so tmux navigation and terminal-style copy can coexist.
mouse-shift-capture = never

# ── Shell ────────────────────────────────────────────────────────────────────
shell-integration = fish
shell-integration-features = cursor,no-sudo,title,ssh-terminfo,ssh-env

# ── Keybinds ─────────────────────────────────────────────────────────────────
keybind = ctrl+shift+j=write_screen_file:paste
keybind = global:cmd+alt+s=toggle_quick_terminal
keybind = super+shift+home=scroll_to_top

# Claude Code
keybind = shift+enter=text:\n

# Ghostty tab switching
keybind = shift+cmd+t=new_tab
keybind = cmd+left=previous_tab
keybind = cmd+right=next_tab

# tmux keymaps using C-a prefix
keybind = cmd+t=text:\x01c
keybind = cmd+d=text:\x01i
keybind = shift+cmd+d=text:\x01u
keybind = cmd+digit_1=text:\x011
keybind = cmd+digit_2=text:\x012
keybind = cmd+digit_3=text:\x013
keybind = cmd+digit_4=text:\x014
keybind = cmd+digit_5=text:\x015
keybind = cmd+digit_6=text:\x016
keybind = cmd+digit_7=text:\x017
keybind = cmd+digit_8=text:\x018
keybind = cmd+digit_9=text:\x019

# ── Bell & notifications ─────────────────────────────────────────────────────
bell-audio-path = /System/Library/Sounds/Bottle.aiff
bell-features = border,attention,audio
notify-on-command-finish = unfocused
notify-on-command-finish-action = bell,no-notify
notify-on-command-finish-after = 4s

# ── Clipboard ────────────────────────────────────────────────────────────────
clipboard-read = ask
clipboard-trim-trailing-spaces = true
clipboard-paste-protection = true
clipboard-paste-bracketed-safe = true

# ── Theme ────────────────────────────────────────────────────────────────────
theme = Tokyonight Storm
# theme = catppuccin-mocha
# theme = Rose Pine Moon
# background = #000000

# ── Appearance ───────────────────────────────────────────────────────────────
background-opacity = 0.9
background-blur-radius = 20
unfocused-split-opacity = 0.4
split-divider-color = white
cursor-style = bar
cursor-style-blink = true
bold-is-bright = false

# ── Font ─────────────────────────────────────────────────────────────────────
font-family = "Cousine Nerd Font Mono"
font-size = 13
font-thicken = true
font-feature = zero
font-feature = ss02
font-feature = ss03
font-feature = ss04
font-feature = ss05
font-feature = ss06
font-feature = ss07
font-feature = ss08
font-feature = ss09
font-feature = ss10
font-feature = ss11
font-feature = ss13
font-feature = -ss14
font-feature = ss18
font-feature = calt
font-feature = liga

# ── Nerd Font glyph mapping ─────────────────────────────────────────────────
# https://github.com/ryanoasis/nerd-fonts/wiki/Glyph-Sets-and-Code-Points
font-codepoint-map = U+e0b0-U+e0b3,U+e0b4-U+e0c8,U+e0cc-U+e0d4,U+e0ca=Cousine Nerd Font Mono
font-codepoint-map = U+f000-U+f2e0,U+e200-U+e2a9=Cousine Nerd Font Mono
font-codepoint-map = U+e5fa-U+e6b1=Cousine Nerd Font Mono
font-codepoint-map = U+ea60-U+ebeb=Cousine Nerd Font Mono
